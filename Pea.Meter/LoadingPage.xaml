<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.LoadingPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    <Grid
        VerticalOptions="Fill"
        HorizontalOptions="Fill"
        BackgroundColor="Black">

        <!-- <Image Source="pea_load_splash.png" Aspect="AspectFit" /> -->
        <Image Source="pea_amr_intro.png" Aspect="Fill" />
        
        <ActivityIndicator
            IsRunning="True"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <Label
            Margin="0,0,0,0" 
            Text="{x:Static properties:AppResources.Loading}" 
            HorizontalOptions="Center"
            VerticalOptions="Start"
            FontSize="18"
            TextColor="White"/>
    </Grid>
</ContentPage>