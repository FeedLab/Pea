<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pea.Meter.Popup.ErrorPopup"
             Background="Red">

    <VerticalStackLayout
        Margin="12,0">
        <Label
            x:Name="ErrorTitle"
            HorizontalOptions="Center"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="White"
            Text="Error!!!" />

        <Label
            x:Name="ErrorMessage"
            Margin="0,12,0,4"
            HorizontalOptions="Center"
            FontSize="16"
            TextColor="White"
            Text="Error!!!"
            LineBreakMode="WordWrap"/>
    </VerticalStackLayout>
</ContentView>