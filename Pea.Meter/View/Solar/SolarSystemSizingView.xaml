<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="Pea.Meter.View.Solar.SolarSystemSizingView">

        <Grid
            Margin="32,8"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Background="AliceBlue">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <chart:SfCartesianChart
                Grid.Column="0"
                Grid.Row="0"
                HorizontalOptions="Center"
                MinimumWidthRequest="500">

                <chart:SfCartesianChart.Title>
                    <Label
                        Margin="8"
                        HorizontalOptions="Fill"
                        TextColor="Black"
                        HorizontalTextAlignment="Center"
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="Monthly Consumption" />
                </chart:SfCartesianChart.Title>

                <chart:SfCartesianChart.XAxes>
                    <chart:CategoryAxis
                        Interval="1">
                        <chart:CategoryAxis.LabelStyle>
                            <chart:ChartAxisLabelStyle LabelFormat="MMM" />
                        </chart:CategoryAxis.LabelStyle>
                    </chart:CategoryAxis>
                </chart:SfCartesianChart.XAxes>

                <chart:SfCartesianChart.YAxes>
                    <chart:NumericalAxis>
                        <chart:NumericalAxis.Title>
                            <chart:ChartAxisTitle Text="KWh Per Month" />
                        </chart:NumericalAxis.Title>
                    </chart:NumericalAxis>
                </chart:SfCartesianChart.YAxes>

                <!-- Column series with colored data labels -->
                <chart:ColumnSeries ItemsSource="{Binding MeterDataMonthSummary}"
                                    Label="Monthly"
                                    XBindingPath="PeriodStart"
                                    YBindingPath="Total"
                                    Fill="#FCCC8A"
                                    Stroke="#C0A16B"
                                    StrokeWidth="1"
                                    IsVisibleOnLegend="False"
                                    EnableTooltip="True"
                                    CornerRadius="5,5,0,0">

                    <chart:ColumnSeries.DataLabelSettings>
                        <chart:CartesianDataLabelSettings
                            LabelPlacement="Inner"
                            LabelStyle="{chart:ChartDataLabelStyle TextColor=Purple}" />
                    </chart:ColumnSeries.DataLabelSettings>

                </chart:ColumnSeries>
            </chart:SfCartesianChart>

            <chart:SfCartesianChart
                Grid.Row="0"
                Grid.Column="1"
                HorizontalOptions="Center"    
                MinimumWidthRequest="500">

                <chart:SfCartesianChart.Legend>
                    <chart:ChartLegend>
                        <chart:ChartLegend.LabelStyle>
                            <chart:ChartLegendLabelStyle TextColor="Blue" Margin="5" FontSize="18"
                                                         FontAttributes="None" />
                        </chart:ChartLegend.LabelStyle>
                    </chart:ChartLegend>
                </chart:SfCartesianChart.Legend>
                
                <chart:SfCartesianChart.Title>
                    <Label
                        Margin="8"
                        HorizontalOptions="Fill"
                        TextColor="Black"
                        HorizontalTextAlignment="Center"
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="TOU - Peek Usage vs Production" />
                </chart:SfCartesianChart.Title>

                <chart:SfCartesianChart.XAxes>
                    <chart:CategoryAxis
                        Interval="1">
                        <chart:CategoryAxis.LabelStyle>
                            <chart:ChartAxisLabelStyle LabelFormat="MMM" />
                        </chart:CategoryAxis.LabelStyle>
                    </chart:CategoryAxis>
                </chart:SfCartesianChart.XAxes>

                <chart:SfCartesianChart.YAxes>
                    <chart:NumericalAxis>
                        <chart:NumericalAxis.Title>
                            <chart:ChartAxisTitle Text="KWh Per Month" />
                        </chart:NumericalAxis.Title>
                    </chart:NumericalAxis>
                </chart:SfCartesianChart.YAxes>

                <!-- Column series with colored data labels -->
                <chart:ColumnSeries ItemsSource="{Binding MeterReadingMonthlySummary}"
                                    Label="Produced (KW)"
                                    XBindingPath="Date"
                                    YBindingPath="KwProducedPerMonth"
                                    Fill="#D1F9EB"
                                    Stroke="#A4C4B9"
                                    StrokeWidth="1"
                                    IsVisibleOnLegend="True"
                                    EnableTooltip="True"
                                    Spacing="0.3"
                                    CornerRadius="3,3,0,0">
                    
                    <chart:ColumnSeries.DataLabelSettings>
                        <chart:CartesianDataLabelSettings
                            LabelPlacement="Inner"
                            LabelStyle="{chart:ChartDataLabelStyle TextColor=Purple}" />
                    </chart:ColumnSeries.DataLabelSettings>

                </chart:ColumnSeries>
                
                
                <chart:ColumnSeries ItemsSource="{Binding MeterReadingMonthlySummary}"
                                    Label="Consumed (KW)"
                                    XBindingPath="Date"
                                    YBindingPath="KwUsedAtPeek"
                                    Fill="#F79BA6"
                                    Stroke="#D35064"
                                    StrokeWidth="1"
                                    IsVisibleOnLegend="True"
                                    EnableTooltip="True"
                                    Spacing="0.3"
                                    CornerRadius="3,3,0,0">
                    
                    <chart:ColumnSeries.DataLabelSettings>
                        <chart:CartesianDataLabelSettings
                            LabelPlacement="Inner"
                            LabelStyle="{chart:ChartDataLabelStyle TextColor=Purple}" />
                    </chart:ColumnSeries.DataLabelSettings>

                </chart:ColumnSeries>
            </chart:SfCartesianChart>

            <Label 
                Grid.Column="0"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                TextColor="Black"
                Margin="24"
            LineBreakMode="WordWrap"
            FontSize="16">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="With an annual consumption of " />
                        <Span Text="{Binding YearlyConsumption, StringFormat='{}{0:N0}'}" FontAttributes="Bold" />
                        <Span Text=" kWh" FontAttributes="None" />
                        <Span Text=", your facility averages roughly " />
                        <Span Text="{Binding DailyConsumptionAverage6Month, StringFormat='{}{0:N0}'}" FontAttributes="Bold" />
                        <Span Text=" kWh per day based on a six-month peak demand profile (Highest consumption)" FontAttributes="None" />
                        <Span Text=". Currently, your average peak demand during the TOU window (09:00–22:00) sits at " />
                        <Span Text="{Binding DailyPeekConsumptionAverage6Month, StringFormat='{}{0:N0}'}" FontAttributes="Bold" />
                        <Span Text=" kWh" FontAttributes="None" />
                        <Span Text=". By integrating a " />
                        <Span Text="{Binding SolarSizeNeeded, StringFormat='{}{0:N0}'}" FontAttributes="Bold" />
                        <Span Text=" kW solar array" FontAttributes="None" />
                        <Span Text=" paired with a " />
                        <Span Text="{Binding BatterySizeNeeded, StringFormat='{}{0:N0}'}" FontAttributes="Bold" />
                        <Span Text=" kWh battery storage system" FontAttributes="None" />
                        <Span Text=", you can effectively offset the most expensive billing periods with renewable energy, significantly reducing your reliance on the grid during high-tariff hours." />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>

</ContentView>