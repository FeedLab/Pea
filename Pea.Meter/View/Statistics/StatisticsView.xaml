<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:components="clr-namespace:Pea.Meter.View.Components"
             xmlns:local="clr-namespace:Pea.Meter.View"
             xmlns:statistics="clr-namespace:Pea.Meter.View.Statistics"
             x:Class="Pea.Meter.View.Statistics.StatisticsView">

    <Grid>
        <tabView:SfTabView x:Name="TabViewStatistics"
                           Margin="0"
                           FontAutoScalingEnabled="True"
                           ContentTransitionDuration ="500"
                           EnableRippleAnimation="True"
                           HeaderHorizontalTextAlignment="Center"
                           IndicatorCornerRadius ="5"
                           IndicatorPlacement="Bottom"
                           IndicatorBackground="Blue"
                           EnableSwiping="True"
                           HorizontalOptions="Fill"
                           TabBarPlacement="Top"
                           TabWidthMode="SizeToContent"
                           TabBarBackground="Transparent"
                           TabHeaderPadding="0"
                           >
            <tabView:SfTabView.Items>

                <tabView:SfTabItem Header="30 Days Summary" x:Name="Summary30Days" Background="White"
                                   TextColor="Black" FontSize="18">
                    <tabView:SfTabItem.Content>
                        <statistics:MeterReadingsHourView />
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="All Historic Readings" x:Name="AllHistoricReadings" Background="White" TextColor="Black" FontSize="18">
                    <tabView:SfTabItem.Content>
                        <statistics:MeterReadingsDailyView />
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>


            </tabView:SfTabView.Items>
        </tabView:SfTabView>

    </Grid>
</ContentView>