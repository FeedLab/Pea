<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Pea.Meter.View.Components"
             xmlns:viewModel="clr-namespace:Pea.Meter.ViewModel"
             xmlns:statistics="clr-namespace:Pea.Meter.ViewModel.Statistics"
             xmlns:statistics1="clr-namespace:Pea.Meter.View.Statistics"
             x:Class="Pea.Meter.View.Statistics.MeterReadingsHourView"
             x:DataType="statistics:MeterReadingsHourViewModel">

    <statistics1:MeterReadingsHourChart 
        ChartTitle="{Binding DateMeterData, StringFormat='{0:D}'}"
        TodayData="{Binding MeterDataToday}"
        Average1DayData="{Binding MeterDataAverage1}"
        Average7DaysData="{Binding MeterDataAverage7}"
        Average30DaysData="{Binding MeterDataAverage30}" />
</ContentView>
