<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Pea.Meter.Components"
             x:Class="Pea.Meter.View.Components.PeaServicesView">

    <Grid Margin="0,26" VerticalOptions="Fill">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>

        <!-- Item 1 -->
        <components:ServiceBoxComponent 
            Grid.Column="0"
            ImageSource="pea_e_bill.png"
            Title="Electronic Billing"
            Description="Go paperless in Thailand! Save time and trees by getting secure monthly invoices sent to your inbox."
            Url="https://eservice.pea.co.th/ebill" />

        <!-- Item 2 -->
        <components:ServiceBoxComponent 
            Grid.Column="1"
            ImageSource="pea_e_service.png"
            Title="Smart Services"
            Description="Swift, paperless, and global. Securely access all our services from any device, anywhere on Earth"
            Url="https://sabuyservice.pea.co.th/" />

        <!-- Item 3 -->
        <components:ServiceBoxComponent 
            Grid.Column="2"
            ImageSource="pea_solar.png"
            Title="PEA SOLAR"
            Description="Sustainable solar for farms and homes. Powering irrigation and off-grid life 24/7 with zero emissions"
            Url="https://peasolar.pea.co.th/" />

        <!-- Item 4 -->
        <components:ServiceBoxComponent 
            Grid.Column="3"
            ImageSource="pea_transformer.png"
            Title="{OnIdiom Desktop='Transformer Lifecycle Management', Default='Transformer Management'}"
            Description="Comprehensive diagnostic testing, oil analysis, and preventative repairs to ensure grid stability and peak electrical efficiency"
            Url="https://sabuyservice.pea.co.th/service/f54569de-88df-4188-1408-08dcb7573509" />
    </Grid>
</ContentView>