<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Pea.Meter.Components"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.View.Components.PeaServicesView">

    <Grid Margin="0,26" VerticalOptions="Fill">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>

        <!-- Item 1 -->
        <components:ServiceBoxComponent 
            Grid.Column="0"
            ImageSource="pay_your_bill.png"
            Title="{x:Static properties:AppResources.ElectronicBilling}"
            Description="{x:Static properties:AppResources.GoPaperlessInThailand}"
            Url="https://eservice.pea.co.th/ebill" />

        <!-- Item 2 -->
        <components:ServiceBoxComponent 
            Grid.Column="1"
            ImageSource="e_service_everywhere.png"
            Title="{x:Static properties:AppResources.SmartServices}"
            Description="{x:Static properties:AppResources.SwiftPaperlessAndGlobalSecurelyAccess}"
            Url="https://sabuyservice.pea.co.th/" />

        <!-- Item 3 -->
        <components:ServiceBoxComponent 
            Grid.Column="2"
            ImageSource="green_energy_with_solar.png"
            Title="{x:Static properties:AppResources.PEASOLAR}"
            Description="{x:Static properties:AppResources.SustainableSolarForFarmsAndHomes}"
            Url="https://peasolar.pea.co.th/" />

        <!-- Item 4 -->
        <components:ServiceBoxComponent 
            Grid.Column="3"
            ImageSource="transformer_lifecycle_management.png"
            Title="{OnIdiom Desktop={x:Static properties:AppResources.TransformerLifecycleManagement}, Default={x:Static properties:AppResources.TransformerManagement}}"
            Description="{x:Static properties:AppResources.ComprehensiveDiagnosticTestingOil}"
            Url="https://sabuyservice.pea.co.th/service/f54569de-88df-4188-1408-08dcb7573509" />
    </Grid>
</ContentView>