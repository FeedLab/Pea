<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="http://schemas.syncfusion.com/maui"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.View.Components.CustomerInfoPopupView">
    <ContentView.Resources>
        <!-- Icon resources -->
    </ContentView.Resources>

    <Grid
        Padding="0,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Label
            Grid.Row="0"
            Margin="16,0"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            TextColor="Black"
            FontSize="16"
            LineBreakMode="WordWrap"
            HorizontalTextAlignment="Start"
            Text="{x:Static properties:AppResources.PleaseBeAdvisedThatYourAccountAndAllAssociatedDataWillBeRemovedFromTheApp}" />

        <buttons:SfCheckBox
            Grid.Row="1"
            Margin="0,24"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            FontSize="16"
            TextColor="DarkRed"
            FontAttributes="Bold"
            StateChanged="ToggleButton_OnStateChanged"
            Text="{x:Static properties:AppResources.IHaveAFullUnderstandingOfTheSituationPleaseContinue}" />

        <BoxView
            Grid.Row="2"
            Margin="24,0"
            HeightRequest="1"
            Color="LightBlue" />

        <buttons:SfButton
            x:Name="CloseAndRemove"
            Grid.Row="3"
            Margin="0,16,0,-16"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Style="{StaticResource IconButtonStyle}"
            Clicked="CloseAndRemove_OnClicked"
            IsVisible="False"
            Opacity="0"
            ImageSource="{StaticResource RemoveMeterIcon}"
            ToolTipProperties.Text="{x:Static properties:AppResources.CloseAndRemoveAccount}"
            Text="{x:Static properties:AppResources.StartRemovalProcedure}" />

        <buttons:SfButton
            x:Name="Close"
            Grid.Row="3"
            Margin="0,16,0,-16"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Style="{StaticResource IconButtonStyle}"
            Clicked="Close_OnClicked"
            IsVisible="True"
            ImageSource="{StaticResource CloseIcon}"
            ToolTipProperties.Text="{x:Static properties:AppResources.CloseWithoutRemoveAccount}"
            Text="{x:Static properties:AppResources.CloseWhithoutAnyAction}" />
    </Grid>
</ContentView>