<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.View.Components.MeterReadingsDailyChart"
             x:Name="DailyOverviewChartControl">

    <Grid BackgroundColor="White">
        <chart:SfCartesianChart
            Margin="16"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="Transparent">

            <chart:SfCartesianChart.Title>
                <Label
                    Margin="8"
                    HorizontalOptions="Fill"
                    TextColor="Black"
                    HorizontalTextAlignment="Center"
                    FontAttributes="Bold"
                    FontSize="20"
                    Text="{x:Static properties:AppResources.AllMeterReadings}" />
            </chart:SfCartesianChart.Title>

            <chart:SfCartesianChart.XAxes>
                <chart:DateTimeAxis>
                    <chart:DateTimeAxis.LabelStyle>
                        <chart:ChartAxisLabelStyle LabelFormat="yyyy-MM-dd" />
                    </chart:DateTimeAxis.LabelStyle>
                </chart:DateTimeAxis>
            </chart:SfCartesianChart.XAxes>

            <chart:SfCartesianChart.YAxes>
                <chart:NumericalAxis>
                    <chart:NumericalAxis.Title>
                        <chart:ChartAxisTitle Text="{Binding Source={x:Reference DailyOverviewChartControl}, Path=YAxisTitle}" />
                    </chart:NumericalAxis.Title>
                </chart:NumericalAxis>
            </chart:SfCartesianChart.YAxes>

            <chart:SfCartesianChart.ZoomPanBehavior>
                <chart:ChartZoomPanBehavior EnablePanning="True"
                                            EnablePinchZooming="False"
                                            ZoomMode="X" />
            </chart:SfCartesianChart.ZoomPanBehavior>

            <chart:SplineSeries ItemsSource="{Binding MeterDataDailyAggregated}"
                                XBindingPath="PeriodStart"
                                YBindingPath="Total"
                                Fill="{Binding Source={x:Reference DailyOverviewChartControl}, Path=SeriesColor}"
                                StrokeWidth="2"
                                IsVisibleOnLegend="True"
                                EnableTooltip="True" />
        </chart:SfCartesianChart>
    </Grid>
</ContentView>
