<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.View.Components.MeterReadingsDailyChart"
             x:Name="DailyOverviewChartControl">

    <Grid BackgroundColor="White">
        <chart:SfCartesianChart
            Margin="16"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="Transparent">

            <chart:SfCartesianChart.Title>
                <Label
                    Margin="8"
                    HorizontalOptions="Fill"
                    TextColor="Black"
                    HorizontalTextAlignment="Center"
                    FontFamily="Segoe UI Semibold"
                    FontSize="20"
                    Text="{x:Static properties:AppResources.AllMeterReadings}" />
            </chart:SfCartesianChart.Title>

            <chart:SfCartesianChart.XAxes>
                <chart:CategoryAxis ZoomFactor="{Binding ZoomFactor}"
                                    ZoomPosition="1"/>
            </chart:SfCartesianChart.XAxes>

            <chart:SfCartesianChart.YAxes>
                <chart:NumericalAxis>
                    <chart:NumericalAxis.Title>
                        <chart:ChartAxisTitle Text="{Binding Source={x:Reference DailyOverviewChartControl}, Path=YAxisTitle}" />
                    </chart:NumericalAxis.Title>
                </chart:NumericalAxis>
            </chart:SfCartesianChart.YAxes>

            <chart:SfCartesianChart.ZoomPanBehavior>
                <chart:ChartZoomPanBehavior EnablePanning="True"
                                            EnablePinchZooming="True"
                                            ZoomMode="X"
                                            MaximumZoomLevel="{Binding MaximumZoomLevel}"/>
                
            </chart:SfCartesianChart.ZoomPanBehavior>
            
            <chart:StackingColumnSeries ItemsSource="{Binding MeterDataDailyAggregated}"
                                        Label="{x:Static properties:AppResources.Peek}"
                                        XBindingPath="PeriodStart"
                                        YBindingPath="Peek"
                                        GroupingLabel="Kw"
                                        Fill="#CD0000"
                                        Stroke="#890000"
                                        StrokeWidth="1"
                                        IsVisibleOnLegend="True"
                                        EnableTooltip="False"
                                        Spacing="0.3"
                                        CornerRadius="0,0,0,0"
                                        ShowDataLabels="False">
            </chart:StackingColumnSeries>

            <chart:StackingColumnSeries ItemsSource="{Binding MeterDataDailyAggregated}"
                                        Label="{x:Static properties:AppResources.OffPeek}"
                                        XBindingPath="PeriodStart"
                                        YBindingPath="OffPeek"
                                        GroupingLabel="Kw"
                                        Fill="#96CE96"
                                        Stroke="#6D966D"
                                        StrokeWidth="1"
                                        IsVisibleOnLegend="True"
                                        EnableTooltip="False"
                                        Spacing="0.3"
                                        CornerRadius="2,2,0,0"
                                        ShowDataLabels="False">
            </chart:StackingColumnSeries>
        </chart:SfCartesianChart>
    </Grid>
</ContentView>
