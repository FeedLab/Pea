<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             xmlns:buttons="http://schemas.syncfusion.com/maui"
             xmlns:components="clr-namespace:Pea.Meter.View.Components"
             x:Class="Pea.Meter.View.Components.MeterReadingsDailyChart"
             x:Name="DailyOverviewChartControl">

    <ContentView.Resources>
        <DataTemplate x:Key="StackedTooltipTemplateMonthly">
            <VerticalStackLayout Padding="8,6" Spacing="2">
                <Label Text="{Binding Item.PeriodStart, StringFormat='{0:MMM yyyy}'}"
                       FontAttributes="Bold" TextColor="White" FontSize="12" />
                <Label Text="{Binding Item.PeekFormatted, StringFormat='Peak: {0}'}"
                       TextColor="#FF9999" FontSize="11" />
                <Label Text="{Binding Item.OffPeekFormatted, StringFormat='Off-peak: {0}'}"
                       TextColor="#96CE96" FontSize="11" />
                <Label Text="{Binding Item.TotalFormatted, StringFormat='Total: {0}'}"
                       TextColor="White" FontSize="11" FontAttributes="Bold" />
            </VerticalStackLayout>
        </DataTemplate>

        <DataTemplate x:Key="StackedTooltipTemplateDaily">
            <VerticalStackLayout Padding="8,6" Spacing="2">
                <Label Text="{Binding Item.PeriodStart, StringFormat='{0:D}'}"
                       FontAttributes="Bold" TextColor="White" FontSize="12" />
                <Label Text="{Binding Item.PeekFormatted, StringFormat='Peak: {0}'}"
                       TextColor="#FF9999" FontSize="11" />
                <Label Text="{Binding Item.OffPeekFormatted, StringFormat='Off-peak: {0}'}"
                       TextColor="#96CE96" FontSize="11" />
                <Label Text="{Binding Item.TotalFormatted, StringFormat='Total: {0}'}"
                       TextColor="White" FontSize="11" FontAttributes="Bold" />
            </VerticalStackLayout>
        </DataTemplate>
    </ContentView.Resources>

    <Grid BackgroundColor="White">
        <chart:SfCartesianChart
            Margin="16"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            BackgroundColor="Transparent">

            <chart:SfCartesianChart.TooltipBehavior>
                <chart:ChartTooltipBehavior Duration="10" />
            </chart:SfCartesianChart.TooltipBehavior>

            <chart:SfCartesianChart.Title>
                <Grid
                    HorizontalOptions="Fill">

                    <components:IconButton
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Margin="32,12,12,12"
                        Icon="&#xf100;"
                        Tapped="OnMoveToFirstTapped" />

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Label
                            Margin="0,0,32,0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            TextColor="Black"
                            HorizontalTextAlignment="Center"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            Text="{x:Static properties:AppResources.AllMeterReadings}" />

                        <buttons:SfRadioGroup
                            Orientation="Horizontal"
                            VerticalOptions="Center">
                            <buttons:SfRadioButton
                                x:Name="RadioButtonDaily"
                                Text="Daily" Value="Daily"
                                StateChanged="ToggleButton_OnStateChanged" />
                            <buttons:SfRadioButton
                                x:Name="RadioButtonMonthly"
                                Text="Monthly" Value="Monthly"
                                StateChanged="ToggleButton_OnStateChanged" />
                        </buttons:SfRadioGroup>
                    </HorizontalStackLayout>

                    <components:IconButton
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        Margin="12,12,32,12"
                        Icon="&#xf101;"
                        Tapped="OnMoveToLastTapped" />
                </Grid>

            </chart:SfCartesianChart.Title>

            <chart:SfCartesianChart.Legend>
                <chart:ChartLegend>
                    <chart:ChartLegend.LabelStyle>
                        <StaticResource Key="DefaultChartLegendLabelStyle" />
                    </chart:ChartLegend.LabelStyle>
                </chart:ChartLegend>
            </chart:SfCartesianChart.Legend>

            <chart:SfCartesianChart.XAxes>
                <chart:CategoryAxis ZoomFactor="{Binding ZoomFactor}"
                                    ZoomPosition="{Binding ZoomPosition}" />
            </chart:SfCartesianChart.XAxes>

            <chart:SfCartesianChart.YAxes>
                <chart:NumericalAxis>
                    <chart:NumericalAxis.Title>
                        <chart:ChartAxisTitle
                            Text="{Binding Source={x:Reference DailyOverviewChartControl}, Path=YAxisTitle}" />
                    </chart:NumericalAxis.Title>
                </chart:NumericalAxis>
            </chart:SfCartesianChart.YAxes>

            <chart:SfCartesianChart.ZoomPanBehavior>
                <chart:ChartZoomPanBehavior EnablePanning="True"
                                            EnablePinchZooming="True"
                                            ZoomMode="X"
                                            MaximumZoomLevel="{Binding MaximumZoomLevel}" />

            </chart:SfCartesianChart.ZoomPanBehavior>

            <chart:StackingColumnSeries x:Name="ColumnSeriesPeek" ItemsSource="{Binding MeterDataAggregated}"
                                        Label="{x:Static properties:AppResources.Peek}"
                                        XBindingPath="PeriodStart"
                                        YBindingPath="Peek"
                                        GroupingLabel="Kw"
                                        Fill="#CD0000"
                                        Stroke="#890000"
                                        StrokeWidth="1"
                                        IsVisibleOnLegend="True"
                                        EnableTooltip="True"
                                        Spacing="0.3"
                                        CornerRadius="0,0,0,0"
                                        ShowDataLabels="False">
            </chart:StackingColumnSeries>

            <chart:StackingColumnSeries x:Name="ColumnSeriesOffPeek" ItemsSource="{Binding MeterDataAggregated}"
                                        Label="{x:Static properties:AppResources.OffPeek}"
                                        XBindingPath="PeriodStart"
                                        YBindingPath="OffPeek"
                                        GroupingLabel="Kw"
                                        Fill="#96CE96"
                                        Stroke="#6D966D"
                                        StrokeWidth="1"
                                        IsVisibleOnLegend="True"
                                        EnableTooltip="True"
                                        Spacing="0.3"
                                        CornerRadius="2,2,0,0"
                                        ShowDataLabels="False">
            </chart:StackingColumnSeries>
        </chart:SfCartesianChart>
    </Grid>
</ContentView>