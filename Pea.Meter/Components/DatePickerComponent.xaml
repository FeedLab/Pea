<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:picker="clr-namespace:Syncfusion.Maui.Picker;assembly=Syncfusion.Maui.Picker"
             x:Class="Pea.Meter.Components.DatePickerComponent"
             x:Name="DatePickerRoot">
    
    <VerticalStackLayout>
        <Grid HeightRequest="60">
            <Border
                x:Name="DateCtrl"
                BackgroundColor="White"
                Stroke="LightBlue"
                StrokeShape="RoundRectangle 5,5,5,5" 
                HorizontalOptions="Center" 
                VerticalOptions="Center"
                Margin="0"
                Padding="0">
                <Grid 
                    Margin="4,0,10,0"
                    VerticalOptions="Center" 
                    HeightRequest="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label
                        TextColor="CadetBlue" 
                        FontSize="15"
                        FontFamily="FontSolid" 
                        HorizontalOptions="Center"
                        VerticalOptions="Center"                        
                        Text="{Binding Source={x:Reference DatePickerRoot}, Path=Glyph}" />

                    <Label 
                        Grid.Column="1" 
                        Text="{Binding Source={x:Reference DatePickerRoot}, Path=Label}" 
                        Margin="0, 0, 5, 0"
                        TextColor="Black"
                        FontSize="15" 
                        VerticalOptions="Center" 
                        LineBreakMode="WordWrap" />

                    <Label 
                        Grid.Column="2" 
                        Text="{Binding Source={x:Reference DatePickerRoot}, Path=SelectedDate, StringFormat='{0:D}'}" 
                        FontSize="15"
                        TextColor="Black"
                        VerticalTextAlignment="Center" 
                        LineBreakMode="WordWrap" />

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDateTapGestureTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>
        </Grid>

        <picker:SfDatePicker
            x:Name="DatePicker"
            Mode="Dialog"
            RelativePosition="AlignBottom"
            TextDisplayMode="FadeAndShrink"
            MaximumDate="{Binding Source={x:Reference DatePickerRoot}, Path=MaximumDate}"
            MinimumDate="{Binding Source={x:Reference DatePickerRoot}, Path=MinimumDate}"
            RelativeView="{x:Reference DateCtrl}"
            SelectedDate="{Binding Source={x:Reference DatePickerRoot}, Path=SelectedDate}"
            OkButtonClicked="OnDatePickerOkButtonClicked">
            <picker:SfDatePicker.HeaderView>
                <picker:PickerHeaderView Text="{Binding Source={x:Reference DatePickerRoot}, Path=HeaderText}" Height="40" />
            </picker:SfDatePicker.HeaderView>

            <picker:SfDatePicker.FooterView>
                <picker:PickerFooterView ShowOkButton="True" Height="40" />
            </picker:SfDatePicker.FooterView>
        </picker:SfDatePicker>
        
        <VerticalStackLayout.Shadow>
            <StaticResource Key="PanelShadow" />
        </VerticalStackLayout.Shadow>
    </VerticalStackLayout>
</ContentView>
