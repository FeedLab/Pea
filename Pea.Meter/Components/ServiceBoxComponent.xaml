<?xml version="1.0" encoding="utf-8"?>

<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="Pea.Meter.Components.ServiceBoxComponent"
        x:Name="Root"
        BackgroundColor="White"
        StrokeThickness="0"
        VerticalOptions="Fill"
        Margin="32,0">
    <Border.StrokeShape>
        <RoundRectangle CornerRadius="8" />
    </Border.StrokeShape>
    <Border.Shadow>
        <StaticResource Key="PanelShadow" />
    </Border.Shadow>
    <Border.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnTapped" />
    </Border.GestureRecognizers>
    
    <VerticalStackLayout Spacing="8" Padding="12" Margin="8" HorizontalOptions="Center">
        <Image Source="{Binding ImageSource, Source={x:Reference Root}}" Aspect="AspectFit" />
        <Label Text="{Binding Title, Source={x:Reference Root}}" 
               FontAttributes="{OnIdiom Desktop=Bold, Default=Bold}"
               HorizontalTextAlignment="{OnIdiom Desktop=Start, Default=Center}"
               TextColor="Black"
               FontSize="12" />
        <Label Text="{Binding Description, Source={x:Reference Root}}"
               HorizontalTextAlignment="Start"
               TextColor="Black"
               FontSize="10"
               IsVisible="{OnIdiom Desktop=True, Default=False}" />
    </VerticalStackLayout>
</Border>
