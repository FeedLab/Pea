<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:properties="clr-namespace:Pea.Meter.Resources.Strings"
             x:Class="Pea.Meter.Components.TouVsFlatRateView.TouCalculationResult">
    <Border
        Style="{StaticResource MainPanelBorder}"
        HorizontalOptions="Center"
        VerticalOptions="Center"
        Padding="20">

        <VerticalStackLayout Spacing="12">
            <Image
                Margin="12"
                Source="banner_tou.png"
                Aspect="AspectFit"
                HeightRequest="100"
                HorizontalOptions="Center"
                VerticalOptions="Start" />

            <!-- Title -->
            <Label Text="{x:Static properties:AppResources.ElectricityTariffComparisonSummary}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center" />

            <!-- Intro -->
            <Label
                Text="{x:Static properties:AppResources.ToUComparisonBetweenTheTimeOfUseTOUTariff}"
                FontSize="16"
                TextColor="Black"
                LineBreakMode="WordWrap" />

            <!-- Key figures with mixed styles -->
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{x:Static properties:AppResources.TariffCalculation_TOUTotalCost}" FontSize="14"
                              TextColor="Black" />
                        <Span Text=" " />
                        <Span Text="{Binding TouTotalCost, StringFormat='{}{0:N0} THB'}" FontSize="14"
                              FontAttributes="Bold" TextColor="ForestGreen" />
                        
                        <!-- New line -->
                        <Span Text="&#10;" />

                        <Span Text="{x:Static properties:AppResources.TariffCalculation_FlatRateTotalCost}"
                              TextColor="Black" />
                        <Span Text=" " />
                        <Span Text="{Binding FlatRateTotalCost, StringFormat='{}{0:N0} THB'}" FontSize="14"
                              FontAttributes="Bold" TextColor="Crimson" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <!-- Highlighted savings -->
            <Label FontSize="14"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{x:Static properties:AppResources.ThisMeansTheTOUTariffResultsInASavingsOf}"
                              TextColor="Black" />
                        <Span Text=" " />
                        <Span Text="{Binding DiffInCurrency, StringFormat='{}{0:N0}'}"
                              TextColor="ForestGreen" />
                        <Span Text=" " />
                        <Span Text="{x:Static properties:AppResources.THBEquivalentToApproximately}"
                              TextColor="Black" />
                        <Span Text=" " />
                        <Span Text="{Binding DiffInPercent, StringFormat='{}{0:n1}'}"
                              TextColor="ForestGreen" />
                        <Span Text=" " />
                        <Span Text="{x:Static properties:AppResources.LowerCostComparedToTheFlatRateOption}"
                              TextColor="Black" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <!-- Conclusion -->
            <Label
                Text="{x:Static properties:AppResources.ToUInConclusionBased}"
                FontSize="14"
                TextColor="Black"
                LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </Border>
</ContentView>