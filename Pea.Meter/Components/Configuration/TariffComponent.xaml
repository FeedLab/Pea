<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sliders="http://schemas.syncfusion.com/maui"
             xmlns:components="clr-namespace:Pea.Meter.Components"
             x:Class="Pea.Meter.Components.Configuration.TariffComponent"
             x:Name="This">

    <ScrollView Padding="0,0,0,0">
        <VerticalStackLayout
            Padding="16,0"
            HorizontalOptions="Fill"
            VerticalOptions="Start">

            <components:SwitchComponent
                LabelText="Type Of Tariff"
                IsOn="{Binding Source={x:Reference This}, Path=TariffConfiguration.IsTariffTypeTimeOfUse}"
                TextWhenOn="Time Of Use"
                TextWhenOff="FlatRate" />


            <components:SliderComponent
                LabelText="FlatRate Price"
                Minimum="3.5"
                Maximum="4.5"
                Value="{Binding Source={x:Reference This}, Path=TariffConfiguration.FlatRatePrice}"
                StepSize="0.01"
                Interval="0.25"
                NumberFormat="0.00"
                ThumbNumberFormat="{}{0:N2}"
                ThumbColor="#C2FFFF" />

            <components:SliderComponent
                LabelText="Peak Price"
                Minimum="4.75"
                Maximum="6.0"
                Value="{Binding Source={x:Reference This}, Path=TariffConfiguration.PeekPrice}"
                StepSize="0.01"
                Interval="0.25"
                NumberFormat="0.00"
                ThumbNumberFormat="{}{0:N2}"
                ThumbColor="Red" />

            <components:SliderComponent
                LabelText="OffPeak Price"
                Minimum="2.0"
                Maximum="3.0"
                Value="{Binding Source={x:Reference This}, Path=TariffConfiguration.OffPeekPrice}"
                StepSize="0.01"
                Interval="0.25"
                NumberFormat="0.00"
                ThumbNumberFormat="{}{0:N2}"
                ThumbColor="MediumSeaGreen" />


            <components:SliderComponent
                LabelText="Invoice Day (Day in month)"
                Minimum="1"
                Maximum="31"
                Value="{Binding Source={x:Reference This}, Path=TariffConfiguration.InvoiceDayInMonth}"
                StepSize="1"
                Interval="5"
                NumberFormat="0"
                ThumbNumberFormat="{}{0:N0}"
                ThumbColor="Coral" />


        </VerticalStackLayout>
    </ScrollView>
</ContentView>