<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sliders="http://schemas.syncfusion.com/maui"
             x:Class="Pea.Meter.Components.SwitchComponent">

    <Border
        HorizontalOptions="Fill"
        VerticalOptions="Start"
        Stroke="LightGray"
        StrokeThickness="0"
        BackgroundColor="White"
        Margin="8"
        StrokeShape="RoundRectangle 8">
        <Border.Shadow>
            <StaticResource Key="PanelShadow" />
        </Border.Shadow>

        <Grid
            HorizontalOptions="Start"
            VerticalOptions="Start">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>

            <Label
                Margin="12,8,0,0"
                Grid.Row="0"
                TextColor="Black"        
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                Text="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=LabelText}" />

            <HorizontalStackLayout
                Grid.Row="1"
                Margin="32,8,0,8">
                <sliders:SfSwitch
                    x:Name="Switch"
                    IsOn="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=IsOn, Mode=TwoWay}" />

                <Label
                    Margin="12,0,0,8"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    TextColor="Black"
                    FontFamily="OpenSansSemibold"
                    Text="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=TextWhenOff}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Source={x:Reference Switch}, Path=IsOn}"
                                     Value="True">
                            <Setter Property="Text" Value="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=TextWhenOn}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>
