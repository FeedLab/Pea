<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:sliders="clr-namespace:Syncfusion.Maui.Sliders;assembly=Syncfusion.Maui.Sliders"
        x:Class="Pea.Meter.Components.SliderComponent"
        x:Name="Root"
        HorizontalOptions="Start"
        VerticalOptions="Start"
        Stroke="LightGray"
        StrokeThickness="0"
        BackgroundColor="White"
        Margin="8"
        StrokeShape="RoundRectangle 8">
    <Border.Shadow>
        <StaticResource Key="PanelShadow" />
    </Border.Shadow>
    
    <Grid
        HorizontalOptions="Start"
        VerticalOptions="Start">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Label
            Margin="12,8,0,0"
            Grid.Row="0"
            TextColor="Black"
            FontAttributes="Bold"
            FontFamily="OpenSansSemibold"
            Text="{Binding LabelText, Source={x:Reference Root}}" />

        <sliders:SfSlider
            x:Name="Slider"
            Grid.Row="1"
            Margin="8,8"
            HorizontalOptions="Fill"
            VerticalOptions="Start"
            NumberFormat="{Binding NumberFormat, Source={x:Reference Root}}"
            EdgeLabelsPlacement="Default"
            Interval="{Binding Interval, Source={x:Reference Root}}"
            ShowLabels="True"
            ShowTicks="True"
            Minimum="{Binding Minimum, Source={x:Reference Root}}"
            Maximum="{Binding Maximum, Source={x:Reference Root}}"
            Value="{Binding Value, Source={x:Reference Root}, Mode=TwoWay}"
            StepSize="{Binding StepSize, Source={x:Reference Root}}"
            ValueChanged="Slider_OnValueChanged">

            <sliders:SfSlider.ThumbStyle>
                <sliders:SliderThumbStyle
                    Radius="19"
                    Fill="{Binding ThumbColor, Source={x:Reference Root}}" />
            </sliders:SfSlider.ThumbStyle>

            <sliders:SfSlider.ThumbIcon>
                <VerticalStackLayout>
                    <HorizontalStackLayout>
                        <Label Margin="18"
                               Text="{Binding Source={x:Reference Slider}, Path=Value, StringFormat='{Binding ThumbNumberFormat, Source={x:Reference Root}}'}"
                               TextColor="Black"
                               x:DataType="sliders:SfSlider" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </sliders:SfSlider.ThumbIcon>
        </sliders:SfSlider>
    </Grid>
</Border>
