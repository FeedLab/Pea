<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfEffects="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="Pea.Meter.Components.ToolbarComponent"
             x:Name="Root">


    <Grid Padding="8,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0" Margin="0,0,8,0" Text="&#xf013;"
               ToolTipProperties.Text="Configuration"
               Style="{StaticResource IconLabel}">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnConfigurationTapped" />
            </Label.GestureRecognizers>
            <Label.Shadow>
                <Shadow Radius="15"
                        Opacity="0.6"
                        Brush="Black"
                        Offset="10,10" />
            </Label.Shadow>
        </Label>

        <Image
            Grid.Column="1"
            Margin="8,10,8,8"
            Source="{Binding FlagSource, Source={x:Reference Root}}"
            HeightRequest="28"
            Aspect="AspectFit"
            ToolTipProperties.Text="Language">
            <Image.Shadow>
                <Shadow Radius="15"
                        Opacity="0.6"
                        Brush="Black"
                        Offset="10,10" />
            </Image.Shadow>
            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnConfigurationFlagTapped" />
            </Image.GestureRecognizers>
        </Image>


        <Label Grid.Column="2" Margin="40,0,0,0" Text="&#xf2f5;"
               ToolTipProperties.Text="Quit"
               Style="{StaticResource IconLabel}">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnQuitTapped" />
            </Label.GestureRecognizers>
            <Label.Shadow>
                <Shadow Radius="15"
                        Opacity="0.6"
                        Brush="Black"
                        Offset="10,10" />
            </Label.Shadow>
        </Label>

    </Grid>
</ContentView>